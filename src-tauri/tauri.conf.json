{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "foqus",
  "version": "0.2.0",
  "identifier": "com.foqus.writer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "foqus",
        "width": 1000,
        "height": 720,
        "minWidth": 480,
        "minHeight": 420,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$APPDATA/**", "$APPLOCALDATA/**", "$TEMP/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2OUU4RTY1NzJGRDgzNDYKUldSR2cvMXlaWTZlMWsvNVo3NGhOWGt0UHJTUU9Tckd5NXBLY05Ob25RT3UrWlZ5cEJwSTN0NHMK",
      "endpoints": [
        "https://github.com/LumHum/foqus/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "txt", "text"],
        "name": "Markdown Document",
        "description": "Markdown text document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "background": "installer/dmg-background.png",
        "windowSize": { "width": 660, "height": 420 },
        "appPosition": { "x": 165, "y": 212 },
        "applicationFolderPosition": { "x": 495, "y": 212 }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/nsis-header.bmp",
        "sidebarImage": "installer/nsis-sidebar.bmp"
      }
    },
    "linux": {
      "deb": { "depends": [] }
    }
  }
}
